{
    "name": "t3/size",
    "type": "typo3-cms-extension",
    "version": "0.1.0-dev",
    "description": "Displays TYPO3 CMS storage usage information in the backend.",
    "keywords": [
        "TYPO3 CMS",
        "Storage usage",
        "File size",
        "Database size"
    ],
    "homepage": "https://github.com/a-r-m-i-n/size",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Armin Vieweg",
            "role": "Developer",
            "email": "armin@v.ieweg.de",
            "homepage": "https://v.ieweg.de"
        }
    ],
    "require": {
        "php": "^8.2",
        "typo3/cms-core": "^13.4 || ^14.3",
        "typo3/cms-backend": "^13.4 || ^14.3"
    },
    "require-dev": {
        "ext-zip": "*",
        "typo3/cms-dashboard": "^13.4 || ^14.3",
        "typo3/cms-scheduler": "^13.4 || ^14.3",
        "armin/editorconfig-cli": "^2.2.1",
        "friendsofphp/php-cs-fixer": "^3.95.2",
        "jangregor/phpstan-prophecy": "^2.3",
        "phpstan/phpstan": "^2.1.55",
        "phpstan/phpstan-doctrine": "^2.0.22",
        "saschaegerer/phpstan-typo3": "^3.0.1"
    },
    "autoload": {
        "psr-4": {
            "T3\\Size\\": "Classes"
        }
    },
    "replace": {
        "typo3-ter/size": "*"
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "size"
        }
    },
    "config": {
        "allow-plugins": {
            "typo3/cms-composer-installers": true,
            "typo3/class-alias-loader": true
        }
    },
    "scripts": {
        "check": [
            "@editorconfig",
            "@phpcs",
            "@phpstan"
        ],
        "fix": [
            "@editorconfig:fix",
            "@phpcs:fix",
            "@phpstan"
        ],
        "editorconfig": "ec -unv -e public/assets -e var -e tmp",
        "editorconfig:fix": "ec -unvf -e public/assets -e var -e tmp",
        "phpcs": "php-cs-fixer fix --config .build/php-cs-rules.php --ansi --verbose --diff --dry-run",
        "phpcs:fix": "php-cs-fixer fix --config .build/php-cs-rules.php --ansi",
        "phpstan": "phpstan analyse -c .build/phpstan.neon",
        "ter": "php .build/create-ter-zip.php"
    }
}
